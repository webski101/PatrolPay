# Copy to .env and fill in. NEVER commit .env.

# Funded account on BOT Chain testnet (get funds: https://faucet.botchain.ai/basic)
# Used by `npm run deploy` to deploy + register + deposit budget.
DEPLOYER_PRIVATE_KEY=0xyour_deployer_private_key_here

# Account that pays gas for submitReceipt txs. Can be the same as the deployer.
RELAYER_PRIVATE_KEY=0xyour_relayer_private_key_here

# The device's signing key. Leave blank — device.js / deploy.js will generate
# one and write it here automatically (it is never printed to the console).
DEVICE_PRIVATE_KEY=

# Filled in automatically by `npm run deploy`, or paste manually.
CONTRACT_ADDRESS=

# Optional overrides
RPC_URL=https://rpc.bohr.life
CHAIN_ID=968
# Initial budget deposited at deploy time, in native tokens (default 0.5)
INITIAL_BUDGET=0.5
# Payment per verified receipt, in native tokens (default 0.001)
RATE_PER_RECEIPT=0.001
# Hourly receipt cap per device (default 720 = one per 5s)
MAX_RECEIPTS_PER_HOUR=720
# Dashboard port
PORT=3000
